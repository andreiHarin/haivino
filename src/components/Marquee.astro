---
interface Props {
  text: string;
  variant?: "burgundy" | "cream";
}

const { text, variant = "burgundy" } = Astro.props;

const bg = variant === "burgundy" ? "bg-burgundy text-cream" : "bg-cream-deep text-burgundy";
---
<section class={`overflow-hidden ${bg} py-3 md:py-4`} aria-label={text}>
  <div class="marquee-track flex gap-12 whitespace-nowrap text-sm md:text-base uppercase tracking-[0.25em] font-medium">
    {Array.from({ length: 8 }).map(() => (
      <span class="flex items-center gap-12">
        <span>{text}</span>
        <span aria-hidden="true">·</span>
      </span>
    ))}
  </div>
</section>
