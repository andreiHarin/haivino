---
import { t, type Locale } from "../i18n/utils";
import { contacts } from "../data/contacts";

interface Props { locale: Locale }
const { locale } = Astro.props;
const tr = t(locale);
const year = new Date().getFullYear();
---
<footer class="bg-burgundy text-cream/95 mt-16">
  <div class="mx-auto max-w-6xl px-4 md:px-6 py-12 grid gap-10 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="font-display text-2xl md:text-3xl text-cream">{contacts.name}</div>
      <p class="mt-3 text-cream/80 max-w-md">{tr.footer.tagline}</p>
    </div>

    <div>
      <h2 class="font-display text-lg text-gold mb-3">{tr.footer.contactHeader}</h2>
      <address class="not-italic space-y-1 text-sm leading-relaxed">
        <div>{contacts.address.formatted}</div>
        <div>
          <a href={`tel:${contacts.phone.tel}`} class="underline-offset-4 hover:underline">{contacts.phone.national}</a>
        </div>
      </address>

      <h2 class="font-display text-lg text-gold mt-6 mb-3">{tr.footer.hoursHeader}</h2>
      <p class="text-sm text-cream/70">{tr.contact.hoursPlaceholder}</p>
    </div>

    <div>
      <h2 class="font-display text-lg text-gold mb-3">{tr.footer.menuHeader}</h2>
      <ul class="text-sm space-y-1.5">
        <li><a class="hover:text-gold" href={`${import.meta.env.BASE_URL}${locale === "ro" ? "" : "en/"}`}>{tr.nav.home}</a></li>
        <li><a class="hover:text-gold" href={`${import.meta.env.BASE_URL}${locale === "ro" ? "despre/" : "en/about/"}`}>{tr.nav.about}</a></li>
        <li><a class="hover:text-gold" href={`${import.meta.env.BASE_URL}${locale === "ro" ? "meniu/" : "en/menu/"}`}>{tr.nav.menu}</a></li>
        <li><a class="hover:text-gold" href={`${import.meta.env.BASE_URL}${locale === "ro" ? "contact/" : "en/contact/"}`}>{tr.nav.contact}</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-cream/15">
    <div class="mx-auto max-w-6xl px-4 md:px-6 py-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-2 text-xs text-cream/60">
      <div>© {year} {contacts.name}.</div>
      <div class="flex gap-4">
        <span class="opacity-60">{tr.footer.policy}</span>
        <span class="opacity-60">{tr.footer.cookies}</span>
      </div>
    </div>
  </div>
</footer>
