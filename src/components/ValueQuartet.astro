---
interface Item { title: string; body: string }
interface Props { items: Item[] }

const { items } = Astro.props;
---
<section class="bg-cream-deep">
  <div class="mx-auto max-w-6xl px-4 md:px-6 py-14 md:py-20 grid gap-6 md:gap-8 sm:grid-cols-2 lg:grid-cols-4">
    {items.map((item) => (
      <article class="bg-cream rounded-[var(--radius-card)] p-6 shadow-[var(--shadow-soft)]">
        <h3 class="font-display text-xl text-burgundy mb-2">{item.title}</h3>
        <p class="text-sm leading-relaxed text-ink/80">{item.body}</p>
      </article>
    ))}
  </div>
</section>
