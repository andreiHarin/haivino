---
import { Image } from "astro:assets";
import { t, type Locale } from "../../i18n/utils";
import foodImg from "../../../media/placeholders/placeholder-food.png";

interface Props { locale: Locale }
const { locale } = Astro.props;
const tr = t(locale);
---
<section class="mx-auto max-w-3xl px-4 md:px-6 pt-16 md:pt-24 text-center">
  <h1 class="font-display text-4xl md:text-5xl text-burgundy">{tr.menu.title}</h1>
  <p class="mt-4 text-lg text-ink/75">{tr.menu.intro}</p>
  <p class="mt-3 inline-block text-xs uppercase tracking-[0.25em] text-gold bg-cream-deep px-3 py-1 rounded-full">
    {tr.menu.placeholderNote}
  </p>
</section>

<section class="mx-auto max-w-6xl px-4 md:px-6 py-12 md:py-20 grid gap-10 md:grid-cols-[2fr_1fr] items-start">
  <div class="grid gap-6 sm:grid-cols-2">
    {tr.menu.sections.map((s) => (
      <article class="bg-cream rounded-[var(--radius-card)] p-6 border border-cream-deep">
        <h2 class="font-display text-2xl text-burgundy mb-2">{s.title}</h2>
        <p class="text-sm leading-relaxed text-ink/80">{s.body}</p>
      </article>
    ))}
  </div>

  <aside class="rounded-[var(--radius-card)] overflow-hidden shadow-[var(--shadow-soft)] sticky top-24">
    <Image src={foodImg} alt="" widths={[360, 720]} sizes="(min-width: 768px) 33vw, 100vw" class="w-full h-auto" />
  </aside>
</section>

<section class="mx-auto max-w-3xl px-4 md:px-6 pb-16 md:pb-20 text-center text-sm text-ink/60">
  <p>{tr.menu.allergenNote}</p>
</section>
